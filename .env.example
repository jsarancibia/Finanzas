# Supabase (Dashboard → Settings → API)
# SUPABASE_URL debe ser la URL del proyecto (https://....supabase.co), no la URI de Postgres.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Opcional: si está definido, solo ese correo (minúsculas) puede usar la app tras login (Supabase Auth).
# Crea el usuario en Supabase → Authentication → Users (sin registro público).
# ALLOWED_AUTH_EMAIL=tu@correo.cl

# Solo servidor (Dashboard → Settings → API → service_role). Nunca en frontend ni en repos públicos.
SUPABASE_SERVICE_ROLE_KEY=

# URI Postgres (Settings → Database) para `npm run db:apply` — aplica todos los .sql en supabase/migrations/
DATABASE_URL=

# UUID de Supabase Auth (Dashboard → Authentication → Users) para `npx tsx src/index.ts "mensaje"` con RPC multi-usuario.
# FINANZAS_AUTH_USER_ID=

# LLM — parser principal de lenguaje natural.
# Con LLM_API_KEY definida se activa; desactiva con ENABLE_LLM=false (o 0 / no).
# Groq (recomendado): https://console.groq.com  → keys empiezan con gsk_
# xAI Grok:          https://console.x.ai       → keys empiezan con xai-
ENABLE_LLM=true
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

# Puerto local opcional (si más adelante expones HTTP)
PORT=3000

# Supabase (Dashboard → Settings → API)
# SUPABASE_URL debe ser la URL del proyecto (https://....supabase.co), no la URI de Postgres.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Solo servidor (Dashboard → Settings → API → service_role). Nunca en frontend ni en repos públicos.
SUPABASE_SERVICE_ROLE_KEY=

# URI Postgres (Settings → Database) para `npm run db:apply` — aplica todos los .sql en supabase/migrations/
DATABASE_URL=

# Grok (xAI): solo si regex + parser flexible no entienden el mensaje (ver processMessage).
# Con LLM_API_KEY definida se activa el fallback salvo ENABLE_LLM=false (o 0 / no).
# ENABLE_LLM=false

# Grok — consola https://console.x.ai (ajusta LLM_MODEL al id exacto de tu cuenta)
LLM_API_KEY=
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-3-mini

# Puerto local opcional (si más adelante expones HTTP)
PORT=3000

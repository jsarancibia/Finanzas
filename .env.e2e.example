# Copia a .env.e2e (no commitear) o define los mismos nombres en GitHub Actions.
#
# URL pública de la app (Vercel, preview o local con otro terminal: npm run dev:web).
E2E_BASE_URL=https://tu-proyecto.vercel.app

# Usuario real en Supabase Auth (mismo correo que ALLOWED_AUTH_EMAIL si usas esa variable en servidor).
E2E_USER_EMAIL=tu@correo.cl
E2E_USER_PASSWORD=

# Local (servidor en otra terminal):
# E2E_BASE_URL=http://localhost:3000

{
  "name": "finanzas-api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend del asistente financiero personal (chat + Supabase + LLM)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:web": "npm run build && node scripts/dev-web.mjs",
    "typecheck": "tsc --noEmit",
    "db:apply": "node scripts/apply-migrations.mjs",
    "db:reset-datos": "node scripts/reset-datos.mjs --yes"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "dotenv": "^16.4.7",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
